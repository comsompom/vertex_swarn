# Serve and Protect Bastion — example environment variables
# Copy to .env and set values. Never commit .env or real API keys.

# MQTT broker (Track 1 swarm)
BASTION_BROKER=127.0.0.1
BASTION_MQTT_PORT=1883

# Flask dashboard HTTP port
BASTION_DASHBOARD_PORT=5000

# OpenAI API key (optional; for node_ai_agent.py suggestions)
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=
